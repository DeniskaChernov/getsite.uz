# Кастомный Caddyfile для Railway (Railpack staticfile provider).
# Railpack подхватывает этот файл из корня репо вместо своего шаблона:
# https://railpack.com/languages/staticfile/
# База — шаблон Railpack; отличия: строгая CSP вместо дефолтной слабой,
# HSTS, полный набор security-заголовков и закрытые служебные пути.

{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges
	}
}

:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	# Служебные файлы репозитория не должны быть доступны публично
	@internal path /docs/* /project/* /scripts/* /_headers /README.md /Caddyfile
	respond @internal 404

	header {
		# Та же строгая CSP, что в <meta> на страницах, + frame-ancestors
		# (работает только как заголовок) и авто-апгрейд http-ссылок
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' https://mc.yandex.ru https://mc.yandex.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://mc.yandex.ru; connect-src 'self' https://mc.yandex.ru https://mc.yandex.com; form-action 'self'; upgrade-insecure-requests"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		# Легаси-фильтр отключён по рекомендации OWASP (защищает CSP)
		X-XSS-Protection "0"
		-Server
	}

	# Статика версионируется через ?v= — можно кэшировать надолго
	header /assets/* Cache-Control "public, max-age=2592000"

	root * /app

	file_server {
		hide .git
		hide .env*
	}

	encode {
		gzip
		zstd
	}

	try_files {path} {path}.html {path}/index.html

	handle_errors {
		rewrite * /{err.status_code}.html
		file_server
	}
}
